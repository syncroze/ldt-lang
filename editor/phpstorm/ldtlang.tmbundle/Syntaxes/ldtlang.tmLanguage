<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>name</key>
	<string>ldtlang</string>
	<key>scopeName</key>
	<string>source.ldtlang</string>
	<key>uuid</key>
	<string>9B4C2D35-1F6A-4E2B-8D72-000000000102</string>
	<key>fileTypes</key>
	<array>
		<string>ldt</string>
	</array>
	<key>patterns</key>
	<array>
		<!-- \x — escape first, so \[if / \[= / \#] never highlight as live syntax -->
		<dict><key>include</key><string>#escape</string></dict>
		<!-- [= expression ] -->
		<dict><key>include</key><string>#emit</string></dict>
		<!-- [# comment #] -->
		<dict>
			<key>name</key>
			<string>comment.block.ldtlang</string>
			<key>begin</key>
			<string>(\[#)</string>
			<key>beginCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.definition.comment.begin.ldtlang</string></dict>
			</dict>
			<key>end</key>
			<string>(#\])</string>
			<key>endCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.definition.comment.end.ldtlang</string></dict>
			</dict>
		</dict>
		<!-- self-closing set: [set path = value] -->
		<dict>
			<key>name</key>
			<string>meta.directive.set.ldtlang</string>
			<key>begin</key>
			<string>(\[set)\s+([A-Za-z_][A-Za-z0-9_.\-]*)\s*(=)</string>
			<key>beginCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>keyword.control.set.ldtlang</string></dict>
				<key>2</key>
				<dict><key>name</key><string>variable.other.ldtlang</string></dict>
				<key>3</key>
				<dict><key>name</key><string>keyword.operator.assignment.ldtlang</string></dict>
			</dict>
			<key>end</key>
			<string>(\])</string>
			<key>endCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>keyword.control.set.end.ldtlang</string></dict>
			</dict>
			<key>contentName</key>
			<string>string.unquoted.value.ldtlang</string>
			<key>patterns</key>
			<array>
				<dict><key>include</key><string>#escape</string></dict>
				<dict><key>include</key><string>#emit</string></dict>
			</array>
		</dict>
		<!-- block set: [set path]value[/set] -->
		<dict>
			<key>name</key>
			<string>meta.directive.set.ldtlang</string>
			<key>begin</key>
			<string>(\[set)\s+([A-Za-z_][A-Za-z0-9_.\-]*)\s*(\])</string>
			<key>beginCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>keyword.control.set.ldtlang</string></dict>
				<key>2</key>
				<dict><key>name</key><string>variable.other.ldtlang</string></dict>
				<key>3</key>
				<dict><key>name</key><string>punctuation.definition.tag.ldtlang</string></dict>
			</dict>
			<key>end</key>
			<string>(\[/set\])</string>
			<key>endCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>keyword.control.set.end.ldtlang</string></dict>
			</dict>
			<key>contentName</key>
			<string>string.unquoted.value.ldtlang</string>
			<key>patterns</key>
			<array>
				<dict><key>include</key><string>#escape</string></dict>
				<dict><key>include</key><string>#emit</string></dict>
			</array>
		</dict>
		<!-- [unset a, b.c] — arguments are dot-paths -->
		<dict>
			<key>name</key>
			<string>meta.directive.unset.ldtlang</string>
			<key>begin</key>
			<string>(\[unset)\b</string>
			<key>beginCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>keyword.control.unset.ldtlang</string></dict>
			</dict>
			<key>end</key>
			<string>(\])</string>
			<key>endCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.definition.tag.ldtlang</string></dict>
			</dict>
			<key>patterns</key>
			<array>
				<dict>
					<key>name</key>
					<string>variable.other.ldtlang</string>
					<key>match</key>
					<string>([A-Za-z_][A-Za-z0-9_.\-]*)</string>
				</dict>
			</array>
		</dict>
		<!-- [if …] / [elseif …] condition headers -->
		<dict>
			<key>name</key>
			<string>meta.directive.condition.ldtlang</string>
			<key>begin</key>
			<string>(\[(?:if|elseif))\b</string>
			<key>beginCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>keyword.control.conditional.ldtlang</string></dict>
			</dict>
			<key>end</key>
			<string>(\])</string>
			<key>endCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.definition.tag.ldtlang</string></dict>
			</dict>
			<key>patterns</key>
			<array>
				<dict><key>include</key><string>#header-terms</string></dict>
			</array>
		</dict>
		<!-- [for vars in iterable] headers -->
		<dict>
			<key>name</key>
			<string>meta.directive.loop.ldtlang</string>
			<key>begin</key>
			<string>(\[for)\b</string>
			<key>beginCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>keyword.control.loop.ldtlang</string></dict>
			</dict>
			<key>end</key>
			<string>(\])</string>
			<key>endCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.definition.tag.ldtlang</string></dict>
			</dict>
			<key>patterns</key>
			<array>
				<dict><key>include</key><string>#header-terms</string></dict>
				<dict>
					<key>name</key>
					<string>variable.other.ldtlang</string>
					<key>match</key>
					<string>([A-Za-z_][A-Za-z0-9_]*)</string>
				</dict>
			</array>
		</dict>
		<!-- argument-less markers (whitespace allowed before ]) -->
		<dict>
			<key>name</key>
			<string>keyword.control.ldtlang</string>
			<key>match</key>
			<string>(\[(?:else|/if|/for|break|continue)\s*\])</string>
		</dict>
	</array>
	<key>repository</key>
	<dict>
		<key>escape</key>
		<dict>
			<key>name</key>
			<string>constant.character.escape.ldtlang</string>
			<key>match</key>
			<string>(\\[^A-Za-z0-9])</string>
		</dict>
		<key>string</key>
		<dict>
			<key>name</key>
			<string>string.quoted.double.ldtlang</string>
			<key>match</key>
			<string>("(?:[^"\\]|\\.)*")</string>
		</dict>
		<key>wordops</key>
		<dict>
			<key>name</key>
			<string>keyword.operator.word.ldtlang</string>
			<key>match</key>
			<string>\b(?:and|or|not|defined|count|contains|starts|ends|with|in|to|by)\b</string>
		</dict>
		<key>number</key>
		<dict>
			<key>name</key>
			<string>constant.numeric.ldtlang</string>
			<key>match</key>
			<string>([+-]?\d+(?:\.\d+)?)</string>
		</dict>
		<key>ref</key>
		<dict>
			<key>name</key>
			<string>variable.other.ldtlang</string>
			<key>match</key>
			<string>(@[A-Za-z_][A-Za-z0-9_.]*)</string>
		</dict>
		<key>operators</key>
		<dict>
			<key>name</key>
			<string>keyword.operator.ldtlang</string>
			<key>match</key>
			<string>(==|!=|&lt;=|&gt;=|&lt;|&gt;|\+|-|\*|/|%)</string>
		</dict>
		<key>filter</key>
		<dict>
			<key>match</key>
			<string>(\|)\s*([A-Za-z_][A-Za-z0-9_]*)\s*(:)?</string>
			<key>captures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.separator.pipe.ldtlang</string></dict>
				<key>2</key>
				<dict><key>name</key><string>support.function.filter.ldtlang</string></dict>
				<key>3</key>
				<dict><key>name</key><string>punctuation.separator.args.ldtlang</string></dict>
			</dict>
		</dict>
		<!-- shared terms for [if]/[elseif]/[for] headers (no filters here —
		     filter chains are [= ] only) -->
		<key>header-terms</key>
		<dict>
			<key>patterns</key>
			<array>
				<dict><key>include</key><string>#string</string></dict>
				<dict><key>include</key><string>#wordops</string></dict>
				<dict><key>include</key><string>#ref</string></dict>
				<dict><key>include</key><string>#number</string></dict>
				<dict><key>include</key><string>#operators</string></dict>
			</array>
		</dict>
		<key>emit</key>
		<dict>
			<key>name</key>
			<string>meta.emit.ldtlang</string>
			<key>begin</key>
			<string>(\[=)</string>
			<key>beginCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.definition.emit.begin.ldtlang</string></dict>
			</dict>
			<key>end</key>
			<string>(\])</string>
			<key>endCaptures</key>
			<dict>
				<key>1</key>
				<dict><key>name</key><string>punctuation.definition.emit.end.ldtlang</string></dict>
			</dict>
			<key>patterns</key>
			<array>
				<dict><key>include</key><string>#string</string></dict>
				<dict><key>include</key><string>#filter</string></dict>
				<dict><key>include</key><string>#wordops</string></dict>
				<dict><key>include</key><string>#ref</string></dict>
				<dict><key>include</key><string>#number</string></dict>
				<dict><key>include</key><string>#operators</string></dict>
			</array>
		</dict>
	</dict>
</dict>
</plist>
